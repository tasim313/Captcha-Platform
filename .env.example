# =============================================================================
# CAPTCHA AUTOMATION PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DEBUG=False

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://captcha_user:secure_password@localhost:5432/captcha_platform
DB_HOST=localhost
DB_PORT=5432
DB_NAME=captcha_platform
DB_USER=captcha_user
DB_PASSWORD=secure_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_CELERY_BROKER_URL=redis://localhost:6379/2
REDIS_CELERY_RESULTS_URL=redis://localhost:6379/3

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-fernet-encryption-key-generate-with-python-cryptography
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Celery Configuration
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT=30000
BROWSER_EXECUTABLE_PATH=/usr/bin/chromium

# -----------------------------------------------------------------------------
# 2Captcha API
# -----------------------------------------------------------------------------
TWOCAPTCHA_API_URL=https://api.2captcha.com
TWOCAPTCHA_DEFAULT_TIMEOUT=120
TWOCAPTCHA_POLLING_INTERVAL=5

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/var/log/captcha_platform/app.log
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Proxy Configuration
# -----------------------------------------------------------------------------
PROXY_POOL_ENABLED=False
PROXY_DEFAULT_TIMEOUT=30

# -----------------------------------------------------------------------------
# Rate Limiting
#-------------
DEFAULT_RATE_LIMIT=60/minute
CAPTCHA_SOLVE_RATE_LIMIT=10/minute
API_BALANCE_CHECK_INTERVAL=300

# -----------------------------------------------------------------------------
# Channels (WebSocket)
# -----------------------------------------------------------------------------
CHANNEL_LAYERS=redis://localhost:6379/4
ASGI_APPLICATION=config.asgi.application